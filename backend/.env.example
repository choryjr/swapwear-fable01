# Puerto de la API
PORT=4000

# Secreto para firmar los JWT (cambialo en producción)
JWT_SECRET=poneme-un-secreto-largo-y-random

# Comisión de plataforma sobre ventas (0.08 = 8%)
PLATFORM_FEE=0.08

# MercadoPago (Checkout Pro). Si los dejás vacíos, los pagos corren en modo MOCK.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# A dónde vuelve el comprador después de pagar
MP_BACK_URL=http://localhost:5173/checkout/resultado

# Ruta del archivo SQLite (opcional)
# DB_FILE=./data/swapwear.db
